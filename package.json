{
  "name": "campaign-manager",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"yarn dev:backend\" \"yarn dev:frontend\"",
    "dev:backend": "yarn workspace backend dev",
    "dev:frontend": "yarn workspace frontend dev",
    "build": "yarn workspaces run build",
    "test": "yarn workspace backend test",
    "test:watch": "yarn workspace backend test -- --watch",
    "migrate": "yarn workspace backend migrate",
    "seed": "yarn workspace backend seed",
    "db:migrate": "yarn workspace backend migrate",
    "db:seed": "yarn workspace backend seed",
    "db:reset": "yarn db:migrate:reset && yarn db:migrate && yarn db:seed",
    "db:migrate:reset": "yarn workspace backend migrate:reset",
    "typecheck": "yarn workspaces run typecheck",
    "lint": "eslint \"packages/*/src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\"",
    "docker:start": "docker compose up",
    "docker:build": "docker compose up --build",
    "docker:stop": "docker compose down"
  },
  "engines": {
    "node": ">=18.0.0",
    "yarn": ">=1.22.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7",
    "@typescript-eslint/parser": "^7",
    "concurrently": "^9.1.2",
    "eslint": "^8",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.3"
  }
}
